{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for MarkShot main, overlay & recording windows",
  "windows": [
    "main",
    "overlay",
    "overlay-*",
    "recording-control",
    "recording-overlay",
    "countdown"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:default",
    "fs:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-image",
    "global-shortcut:default",
    "store:default"
  ]
}
