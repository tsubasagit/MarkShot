{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for MarkShot main & overlay windows",
  "windows": ["main", "overlay"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:default",
    "fs:default",
    "clipboard-manager:default",
    "global-shortcut:default",
    "store:default"
  ]
}
